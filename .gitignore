# ==========================================
# Glass Player Production Gitignore
# ==========================================

# macOS system files
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE & Editor caches / metadata
.vscode/
.idea/
*.suo
*.user
*.userossc
*.sln.docstates
*.sln

# Xcode / Apple Build & Caches
build/
DerivedData/
*.xcodeproj/
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
*.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
xcuserdata/
*.xccheckout
*.moved-aside
*.pin
*.xcresult
*.dSYM/
GlassPlayer/build/

# CMake Build Output & Caches (Windows port)
CMakeCache.txt
CMakeFiles/
CMakeSettings.json
CMakePresets.json
CMakeUserPresets.json
Makefile
cmake_install.cmake
install/
windows/build/

# WinUI 3 Windows port build artifacts
windows/obj/
windows/Win32/
windows/x64/
windows/ARM64/
windows/dist/

# Qt Creator & Qt Build artifacts
*.autosave
*.qmlc
*.jsc
object_script.*
qrc_*.cpp
ui_*.h
*.pro.user
*.pro.user.*

# Compiled C++ Binaries & Libraries (Windows)
*.o
*.obj
*.d
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.zip
*.tar.gz
*.7z

# Dependency directories (locally downloaded)
vendor/mpv-dev/x64/
vendor/mpv-dev/arm64/


# App logs & caches
*.log

# Debug / analysis dump files (developer artifacts)
dumpbin_*.txt
*_exports*.txt
pri_dump*.xml
pri_dump*.txt

# User runtime data
configs/watch_later/

# Local scripts / generated temp files
windows/generate_pri.py

# Local Claude Code tooling
.claude/