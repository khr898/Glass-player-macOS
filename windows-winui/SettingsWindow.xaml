<Window
    x:Class="GlassPlayer.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GlassPlayer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation List -->
        <ListView x:Name="SidebarList" SelectionChanged="OnSidebarSelectionChanged" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <ListViewItem Content="General"/>
            <ListViewItem Content="Video"/>
            <ListViewItem Content="Audio"/>
            <ListViewItem Content="Subtitles"/>
            <ListViewItem Content="Network"/>
            <ListViewItem Content="Scaling"/>
            <ListViewItem Content="Color"/>
            <ListViewItem Content="Anime4K"/>
            <ListViewItem Content="Shortcuts"/>
        </ListView>

        <!-- Settings Pages Stack -->
        <Grid x:Name="ContentStack" Grid.Column="1" Padding="24">
            <!-- General Page -->
            <ScrollViewer x:Name="GeneralPage" Visibility="Visible">
                <StackPanel Spacing="16">
                    <TextBlock Text="General Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <CheckBox x:Name="FullscreenCheck" Content="Start in fullscreen mode" Click="OnSettingCheckClicked"/>
                    <CheckBox x:Name="AutoResumeCheck" Content="Auto-resume playback position" Click="OnSettingCheckClicked"/>
                    <CheckBox x:Name="PlayDropCheck" Content="Play dropped files automatically" Click="OnSettingCheckClicked"/>
                    <CheckBox x:Name="UpdatesCheck" Content="Check for updates on launch" Click="OnSettingCheckClicked"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Video Page -->
            <ScrollViewer x:Name="VideoPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Video Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:Name="HwdecCombo" Header="Hardware Decoding" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="d3d11va"/>
                        <ComboBoxItem Content="d3d11va-copy"/>
                        <ComboBoxItem Content="dxva2-copy"/>
                        <ComboBoxItem Content="no"/>
                    </ComboBox>
                    <CheckBox x:Name="VsyncCheck" Content="Enable V-Sync" Click="OnSettingCheckClicked"/>
                    <CheckBox x:Name="InterpolationCheck" Content="Enable frame interpolation" Click="OnSettingCheckClicked"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Audio Page -->
            <ScrollViewer x:Name="AudioPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Audio Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:Name="AudioDriverCombo" Header="Audio Driver" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="wasapi"/>
                    </ComboBox>
                    <ComboBox x:Name="ChannelsCombo" Header="Audio Channels" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="auto"/>
                        <ComboBoxItem Content="stereo"/>
                        <ComboBoxItem Content="5.1"/>
                        <ComboBoxItem Content="7.1"/>
                    </ComboBox>
                    <CheckBox x:Name="SpdifCheck" Content="Enable SPDIF Pass-through" Click="OnSettingCheckClicked"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Subtitles Page -->
            <ScrollViewer x:Name="SubtitlesPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Subtitle Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBox x:Name="SubFontText" Header="Subtitle Font" Width="200" TextChanged="OnSettingTextChanged"/>
                    <Slider x:Name="SubSizeSlider" Header="Font Size" Minimum="10" Maximum="72" Value="24" Width="200" ValueChanged="OnSettingSliderChanged"/>
                    <CheckBox x:Name="SubBoldCheck" Content="Bold text" Click="OnSettingCheckClicked"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Network Page -->
            <ScrollViewer x:Name="NetworkPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Network Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBox x:Name="CacheSizeText" Header="Cache Size (MB)" Width="200" TextChanged="OnSettingTextChanged"/>
                    <TextBox x:Name="UserAgentText" Header="User Agent" Width="200" TextChanged="OnSettingTextChanged"/>
                    <TextBox x:Name="TimeoutText" Header="Timeout (seconds)" Width="200" TextChanged="OnSettingTextChanged"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Scaling Page -->
            <ScrollViewer x:Name="ScalingPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Scaling Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:Name="ScaleCombo" Header="Upscaling filter" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="bilinear"/>
                        <ComboBoxItem Content="spline36"/>
                        <ComboBoxItem Content="lanczos"/>
                        <ComboBoxItem Content="ewa_lanczossharp"/>
                    </ComboBox>
                    <ComboBox x:Name="CscaleCombo" Header="Chroma upscaling filter" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="bilinear"/>
                        <ComboBoxItem Content="spline36"/>
                        <ComboBoxItem Content="lanczos"/>
                        <ComboBoxItem Content="ewa_lanczossharp"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Color Page -->
            <ScrollViewer x:Name="ColorPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Color &amp; HDR Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <CheckBox x:Name="TargetColorspaceCheck" Content="Request target colorspace hint" Click="OnSettingCheckClicked"/>
                    <CheckBox x:Name="HdrPeakCheck" Content="Compute peak brightness (HDR)" Click="OnSettingCheckClicked"/>
                    <ComboBox x:Name="ToneMappingCombo" Header="Tone Mapping Algorithm" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="bt.2390"/>
                        <ComboBoxItem Content="hable"/>
                        <ComboBoxItem Content="mobius"/>
                        <ComboBoxItem Content="clip"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Anime4K Page -->
            <ScrollViewer x:Name="Anime4KPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Anime4K Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:Name="Anime4KPresetCombo" Header="Default Upscaler Preset" Width="200" SelectionChanged="OnSettingComboChanged">
                        <ComboBoxItem Content="Off"/>
                        <ComboBoxItem Content="ModeA"/>
                        <ComboBoxItem Content="ModeB"/>
                        <ComboBoxItem Content="ModeC"/>
                        <ComboBoxItem Content="ModeAA"/>
                        <ComboBoxItem Content="ModeBB"/>
                        <ComboBoxItem Content="ModeCA"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Shortcuts Page -->
            <ScrollViewer x:Name="ShortcutsPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Keyboard Shortcuts" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="12">
                            <TextBlock Text="Play/Pause:" Height="28" VerticalAlignment="Center"/>
                            <TextBlock Text="Volume Up:" Height="28" VerticalAlignment="Center"/>
                            <TextBlock Text="Volume Down:" Height="28" VerticalAlignment="Center"/>
                            <TextBlock Text="Mute/Unmute:" Height="28" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="12">
                            <Button Content="Space" Width="120" Height="28"/>
                            <Button Content="Up" Width="120" Height="28"/>
                            <Button Content="Down" Width="120" Height="28"/>
                            <Button Content="M" Width="120" Height="28"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
