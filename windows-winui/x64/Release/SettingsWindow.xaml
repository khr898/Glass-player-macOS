<Window
    x:Class="GlassPlayer.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GlassPlayer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation List -->
        <ListView x:ConnectionId='2' x:Name="SidebarList"                                              Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <ListViewItem Content="General"/>
            <ListViewItem Content="Video"/>
            <ListViewItem Content="Audio"/>
            <ListViewItem Content="Subtitles"/>
            <ListViewItem Content="Network"/>
            <ListViewItem Content="Scaling"/>
            <ListViewItem Content="Color"/>
            <ListViewItem Content="Anime4K"/>
            <ListViewItem Content="Shortcuts"/>
        </ListView>

        <!-- Settings Pages Stack -->
        <Grid x:ConnectionId='3' x:Name="ContentStack" Grid.Column="1" Padding="24">
            <!-- General Page -->
            <ScrollViewer x:ConnectionId='4' x:Name="GeneralPage" Visibility="Visible">
                <StackPanel Spacing="16">
                    <TextBlock Text="General Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <CheckBox x:ConnectionId='31' x:Name="FullscreenCheck" Content="Start in fullscreen mode"                              />
                    <CheckBox x:ConnectionId='32' x:Name="AutoResumeCheck" Content="Auto-resume playback position"                              />
                    <CheckBox x:ConnectionId='33' x:Name="PlayDropCheck" Content="Play dropped files automatically"                              />
                    <CheckBox x:ConnectionId='34' x:Name="UpdatesCheck" Content="Check for updates on launch"                              />
                </StackPanel>
            </ScrollViewer>

            <!-- Video Page -->
            <ScrollViewer x:ConnectionId='5' x:Name="VideoPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Video Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:ConnectionId='28' x:Name="HwdecCombo" Header="Hardware Decoding" Width="200"                                         >
                        <ComboBoxItem Content="d3d11va"/>
                        <ComboBoxItem Content="d3d11va-copy"/>
                        <ComboBoxItem Content="dxva2-copy"/>
                        <ComboBoxItem Content="no"/>
                    </ComboBox>
                    <CheckBox x:ConnectionId='29' x:Name="VsyncCheck" Content="Enable V-Sync"                              />
                    <CheckBox x:ConnectionId='30' x:Name="InterpolationCheck" Content="Enable frame interpolation"                              />
                </StackPanel>
            </ScrollViewer>

            <!-- Audio Page -->
            <ScrollViewer x:ConnectionId='6' x:Name="AudioPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Audio Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:ConnectionId='25' x:Name="AudioDriverCombo" Header="Audio Driver" Width="200"                                         >
                        <ComboBoxItem Content="wasapi"/>
                    </ComboBox>
                    <ComboBox x:ConnectionId='26' x:Name="ChannelsCombo" Header="Audio Channels" Width="200"                                         >
                        <ComboBoxItem Content="auto"/>
                        <ComboBoxItem Content="stereo"/>
                        <ComboBoxItem Content="5.1"/>
                        <ComboBoxItem Content="7.1"/>
                    </ComboBox>
                    <CheckBox x:ConnectionId='27' x:Name="SpdifCheck" Content="Enable SPDIF Pass-through"                              />
                </StackPanel>
            </ScrollViewer>

            <!-- Subtitles Page -->
            <ScrollViewer x:ConnectionId='7' x:Name="SubtitlesPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Subtitle Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBox x:ConnectionId='22' x:Name="SubFontText" Header="Subtitle Font" Width="200"                                   />
                    <Slider x:ConnectionId='23' x:Name="SubSizeSlider" Header="Font Size" Minimum="10" Maximum="72" Value="24" Width="200"                                      />
                    <CheckBox x:ConnectionId='24' x:Name="SubBoldCheck" Content="Bold text"                              />
                </StackPanel>
            </ScrollViewer>

            <!-- Network Page -->
            <ScrollViewer x:ConnectionId='8' x:Name="NetworkPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Network Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBox x:ConnectionId='19' x:Name="CacheSizeText" Header="Cache Size (MB)" Width="200"                                   />
                    <TextBox x:ConnectionId='20' x:Name="UserAgentText" Header="User Agent" Width="200"                                   />
                    <TextBox x:ConnectionId='21' x:Name="TimeoutText" Header="Timeout (seconds)" Width="200"                                   />
                </StackPanel>
            </ScrollViewer>

            <!-- Scaling Page -->
            <ScrollViewer x:ConnectionId='9' x:Name="ScalingPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Scaling Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:ConnectionId='17' x:Name="ScaleCombo" Header="Upscaling filter" Width="200"                                         >
                        <ComboBoxItem Content="bilinear"/>
                        <ComboBoxItem Content="spline36"/>
                        <ComboBoxItem Content="lanczos"/>
                        <ComboBoxItem Content="ewa_lanczossharp"/>
                    </ComboBox>
                    <ComboBox x:ConnectionId='18' x:Name="CscaleCombo" Header="Chroma upscaling filter" Width="200"                                         >
                        <ComboBoxItem Content="bilinear"/>
                        <ComboBoxItem Content="spline36"/>
                        <ComboBoxItem Content="lanczos"/>
                        <ComboBoxItem Content="ewa_lanczossharp"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Color Page -->
            <ScrollViewer x:ConnectionId='10' x:Name="ColorPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Color &amp; HDR Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <CheckBox x:ConnectionId='14' x:Name="TargetColorspaceCheck" Content="Request target colorspace hint"                              />
                    <CheckBox x:ConnectionId='15' x:Name="HdrPeakCheck" Content="Compute peak brightness (HDR)"                              />
                    <ComboBox x:ConnectionId='16' x:Name="ToneMappingCombo" Header="Tone Mapping Algorithm" Width="200"                                         >
                        <ComboBoxItem Content="bt.2390"/>
                        <ComboBoxItem Content="hable"/>
                        <ComboBoxItem Content="mobius"/>
                        <ComboBoxItem Content="clip"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Anime4K Page -->
            <ScrollViewer x:ConnectionId='11' x:Name="Anime4KPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Anime4K Settings" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <ComboBox x:ConnectionId='13' x:Name="Anime4KPresetCombo" Header="Default Upscaler Preset" Width="200"                                         >
                        <ComboBoxItem Content="Off"/>
                        <ComboBoxItem Content="ModeA"/>
                        <ComboBoxItem Content="ModeB"/>
                        <ComboBoxItem Content="ModeC"/>
                        <ComboBoxItem Content="ModeAA"/>
                        <ComboBoxItem Content="ModeBB"/>
                        <ComboBoxItem Content="ModeCA"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Shortcuts Page -->
            <ScrollViewer x:ConnectionId='12' x:Name="ShortcutsPage" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Keyboard Shortcuts" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="12">
                            <TextBlock Text="Play/Pause:" Height="28" VerticalAlignment="Center"/>
                            <TextBlock Text="Volume Up:" Height="28" VerticalAlignment="Center"/>
                            <TextBlock Text="Volume Down:" Height="28" VerticalAlignment="Center"/>
                            <TextBlock Text="Mute/Unmute:" Height="28" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="12">
                            <Button Content="Space" Width="120" Height="28"/>
                            <Button Content="Up" Width="120" Height="28"/>
                            <Button Content="Down" Width="120" Height="28"/>
                            <Button Content="M" Width="120" Height="28"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

